PORT=8080
APP_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/craftling?sslmode=disable
JWT_SECRET=dev-secret-change-me
ACCESS_TTL=15m
REFRESH_TTL=720h

# Optional: seed/promote an admin on startup (both required to take effect)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Host agent (MODE=agent) ---
# CONTROL_PLANE_URL=http://localhost:8080
# ADVERTISE_ADDR=localhost:9000   # agent API address the control plane calls back
# ADVERTISE_HOST=127.0.0.1        # player-facing connect host VMs report

# Agent VM backend: "fake" (default, in-memory) or "firecracker" (real microVMs).
# AGENT_RUNTIME=fake

# Firecracker driver (AGENT_RUNTIME=firecracker; requires /dev/kvm). Point these
# at a vmlinux kernel and a directory of per-version rootfs images you provide.
# FC_BINARY=firecracker            # firecracker executable (default: PATH)
# FC_KERNEL=/var/lib/craftling/vmlinux
# FC_IMAGE_DIR=/var/lib/craftling/images
# FC_DEFAULT_IMAGE=minecraft-1.20.4.ext4
# FC_WORK_DIR=                     # per-VM working dirs (default: OS temp dir)
